{
  "name": "@unknownstudio/thoth-cc",
  "version": "0.2.0",
  "description": "Long-term memory and disciplined recall loop for Claude Code agents. Native Rust binary distributed via npm.",
  "license": "(MIT OR Apache-2.0)",
  "repository": {
    "type": "git",
    "url": "https://github.com/unknown-studio-dev/thoth.git"
  },
  "keywords": [
    "rag",
    "code-search",
    "claude-code",
    "mcp",
    "memory",
    "agent"
  ],
  "bin": {
    "thoth": "bin/thoth.js",
    "thoth-mcp": "bin/thoth-mcp.js",
    "thoth-gate": "bin/thoth-gate.js"
  },
  "files": [
    "bin/",
    "scripts/",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js"
  },
  "optionalDependencies": {
    "@unknownstudio/thoth-cc-darwin-arm64": "0.2.0",
    "@unknownstudio/thoth-cc-darwin-x64":   "0.2.0",
    "@unknownstudio/thoth-cc-linux-arm64":  "0.2.0",
    "@unknownstudio/thoth-cc-linux-x64":    "0.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
