{
  "SessionStart": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "thoth --root {THOTH_ROOT} hooks exec session-start",
          "timeout": 10,
          "output": "json"
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "thoth --root {THOTH_ROOT} hooks exec user-prompt-submit",
          "timeout": 10,
          "output": "json"
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Write|Edit|NotebookEdit",
      "hooks": [
        {
          "type": "command",
          "command": "thoth-gate",
          "timeout": 15,
          "output": "json"
        }
      ]
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "thoth-gate",
          "timeout": 15,
          "output": "json"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Bash|Write|Edit|NotebookEdit",
      "hooks": [
        {
          "type": "command",
          "command": "thoth --root {THOTH_ROOT} hooks exec post-tool-use",
          "timeout": 10,
          "output": "json"
        }
      ]
    }
  ],
  "Stop": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "thoth --root {THOTH_ROOT} hooks exec stop",
          "timeout": 15,
          "output": "json"
        }
      ]
    }
  ],
  "PreCompact": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "thoth --root {THOTH_ROOT} hooks exec pre-compact",
          "timeout": 10,
          "output": "json"
        }
      ]
    }
  ]
}
